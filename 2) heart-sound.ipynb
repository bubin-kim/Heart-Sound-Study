import librosa
import librosa.display
import matplotlib.pyplot as plt
import numpy as np

normal_file = '/content/drive/MyDrive/github/normal-sound.wav'
abnormal_file = '/content/drive/MyDrive/github/abnormal-sound.wav'

def process_heart_sound(file_path, title, subplot_pos):
    y, sr = librosa.load(file_path, sr=2000) # 1초를 2000으로 쪼개어 확인
    S = librosa.feature.melspectrogram(y=y, sr=sr, n_mels=128, fmax=500) # 500Hz 아래로 심음 분석에 중요한 정보가 있기에 노이즈 없이 아래만 분석
    S_dB = librosa.power_to_db(S, ref=np.max) # 소리를 데시벨 단위로 변환하여 분석
    
    plt.subplot(2, 1, subplot_pos)
    librosa.display.specshow(S_dB, x_axis='time', y_axis='mel', sr=sr, fmax=500, cmap='coolwarm') # 가로:시간, 세로:멜스케일
    plt.title(title)
    plt.colorbar(format='%+2.0f dB')

plt.figure(figsize=(12, 10))

process_heart_sound(normal_file, 'Normal Heart Sound', 1)
process_heart_sound(abnormal_file, 'Abnormal Heart Sound', 2)

plt.tight_layout()
plt.show()
